{
  "description": "momo session lifecycle: persist the main session id, and kill all jobs spawned by this session when it ends.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/cleanup-session.mjs\" SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/cleanup-session.mjs\" SessionEnd",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
