#!/usr/bin/env node
// Mock `claude` CLI for momo tests. Zero deps, Node built-ins only.
//
// Recognised flags (subset of real claude --help):
//   -p / --print
//   --output-format json
//   --session-id <id>   (pin a deterministic session id)
//   --resume <id>       (resume an existing thread)
//   --effort <e>
//   --help              (self-check: print usage, exit 0)
// Trailing non-flag arg = task prompt.
//
// Behaviour injection (env vars, so momo's spawned child inherits them):
//   MOCK_BEHAVIOR=ok        -> print JSON result, exit 0          (default)
//   MOCK_BEHAVIOR=crash     -> write to stderr, exit non-zero (immediate)
//   MOCK_BEHAVIOR=hardcrash -> SIGSTOP-ish: ignore SIGTERM, sleep forever,
//                              relying on the parent to SIGKILL (no terminal state).
//   MOCK_BEHAVIOR=hang      -> sleep forever (respects nothing); timeout path kills it.
//   MOCK_BEHAVIOR=authfail  -> emit a 401-ish stderr, exit non-zero.
//   MOCK_BEHAVIOR=netfail   -> emit ECONNREFUSED-ish stderr, exit non-zero.
//   MOCK_RESULT=<text>      -> override the result text (default "claude mock done").
//   MOCK_DELAY_MS=<n>       -> sleep n ms before producing output (still finishes).
//   MOCK_TOUCH=<path>       -> append a line to <path> when invoked (proves it ran /
//                              lets serial-lock tests observe interleaving).
//   MOCK_HARDCRASH_PIDFILE=<path> -> write own pid here (so test can SIGKILL it).

import fs from "node:fs";
import process from "node:process";

const argv = process.argv.slice(2);

function has(flag) {
  return argv.includes(flag);
}
function valueOf(flag) {
  const i = argv.indexOf(flag);
  return i >= 0 ? argv[i + 1] : undefined;
}

if (has("--help") || has("-h")) {
  process.stdout.write(
    "Usage: claude -p --output-format json [--session-id <id> | --resume <id>] --effort <e> <task>\n"
  );
  process.exit(0);
}

const sessionId = valueOf("--session-id");
const resumeId = valueOf("--resume");
const effort = valueOf("--effort");
const effectiveSession = resumeId || sessionId || "mock-session";

// Task prompt = last argument that is not a flag and not a flag's value.
const consumed = new Set();
for (const f of ["--session-id", "--resume", "--effort", "--output-format"]) {
  const i = argv.indexOf(f);
  if (i >= 0) {
    consumed.add(i);
    consumed.add(i + 1);
  }
}
let task = "";
for (let i = argv.length - 1; i >= 0; i--) {
  if (consumed.has(i)) continue;
  if (argv[i].startsWith("-")) continue;
  task = argv[i];
  break;
}

const behavior = process.env.MOCK_BEHAVIOR || "ok";
const resultText = process.env.MOCK_RESULT || `claude mock done`;
const delayMs = Number(process.env.MOCK_DELAY_MS || 0);

if (process.env.MOCK_TOUCH) {
  try {
    fs.appendFileSync(process.env.MOCK_TOUCH, `claude ${effectiveSession} ${task}\n`);
  } catch {
    /* ignore */
  }
}

function emitOkAndExit() {
  const payload = {
    type: "result",
    subtype: "success",
    session_id: effectiveSession,
    result: resultText,
    task,
    effort,
  };
  process.stdout.write(JSON.stringify(payload) + "\n");
  process.exit(0);
}

function sleepForever(ignoreSignals) {
  if (process.env.MOCK_HARDCRASH_PIDFILE) {
    try {
      fs.writeFileSync(process.env.MOCK_HARDCRASH_PIDFILE, String(process.pid));
    } catch {
      /* ignore */
    }
  }
  if (ignoreSignals) {
    // Hard crash sim: refuse to terminate gracefully; only SIGKILL stops us.
    process.on("SIGTERM", () => {});
    process.on("SIGINT", () => {});
  }
  // Keep the event loop alive indefinitely.
  setInterval(() => {}, 1 << 30);
}

switch (behavior) {
  case "crash":
    process.stderr.write("mock claude: boom (simulated crash)\n");
    process.exit(3);
    break;
  case "authfail":
    process.stderr.write("API error 401 Unauthorized: invalid api key\n");
    process.exit(1);
    break;
  case "netfail":
    process.stderr.write("request failed: ECONNREFUSED getaddrinfo ENOTFOUND host\n");
    process.exit(1);
    break;
  case "hardcrash":
    // Run forever ignoring SIGTERM; the test SIGKILLs us mid-run so no terminal
    // state is ever written by the runner -> assessJob must detect "crashed".
    sleepForever(true);
    break;
  case "hang":
    // Run forever; the runner's wall-clock timeout must kill us -> "timeout".
    sleepForever(false);
    break;
  case "ok":
  default:
    if (delayMs > 0) {
      setTimeout(emitOkAndExit, delayMs);
    } else {
      emitOkAndExit();
    }
    break;
}
